GEMINI_API_KEY=use your own key

# Default LLM Provider (gemini, openai, groq)
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_MODEL=gemini-3-flash-preview

# OCR Configuration (EasyOCR - No external installation needed!)
OCR_GPU=false

# Image Processing Settings
IMAGE_DPI=300
CONTRAST_FACTOR=1.5
BRIGHTNESS_FACTOR=1.2
GAUSSIAN_BLUR_KERNEL=1

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# File Upload Limits
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=png,jpg,jpeg,bmp,tiff